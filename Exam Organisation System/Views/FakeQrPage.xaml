<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Exam_Organisation_System.Views.FakeQrPage">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout
                Padding="24"
                Spacing="24"
                VerticalOptions="Center">

                <Label
                    Text="QR Kod"
                    FontSize="28"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />

                <Label
                    Text="Sınav salonu kapısındaki QR kodunu taratıyormuş gibi devam edebilirsiniz."
                    HorizontalTextAlignment="Center"
                    TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />

                <Border
                    Padding="16"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Seçilen Sınav"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />
                        <Label
                            Text="{Binding SelectedExam.CourseName}"
                            FontSize="16"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 16"
                    Padding="16"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <Image
                        Source="qr_placeholder.png"
                        HeightRequest="220"
                        WidthRequest="220"
                        Aspect="AspectFit" />
                </Border>

                <Button
                    Text="QR Tara"
                    Command="{Binding ScanCommand}"
                    HeightRequest="52"
                    CornerRadius="12" />

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>