<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Exam_Organisation_System.Views.SettingsPage">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="24">

                <Label
                    Text="Ayarlar"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />

                <Border
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                    StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="Tema Seçimi" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />
                                <Label Text="Uygulamanın temasını seçin: Sistem, Açık veya Koyu." FontSize="13" TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
                            </VerticalStackLayout>
                            <Picker
                                Grid.Column="1"
                                Title="Tema Seçimi"
                                ItemsSource="{Binding ThemeOptions}"
                                SelectedItem="{Binding SelectedTheme}"
                                WidthRequest="120" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                    StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Hakkında" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />
                        <Label Text="Exam Organisation System" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Label Text="Sürüm 1.0.0" TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
                        <Label Text="Çukurova Üniversitesi Bilgi İşlem Ağ ve Destek Birimi"
                               FontSize="18"
                               TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>