<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Exam_Organisation_System.Views.HomePage">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout
                Padding="24,12,24,24"
                Spacing="12">
                <Label
                    Text="Merhaba,"
                    FontSize="18"
                    />
                <Label
                    Text="{Binding Student.FullName}"
                    FontSize="28" />
                <Label
                    Text="{Binding CurrentDate}"
                    FontSize="14"
                    TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}"
                    Margin="0,0,0,8" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,16">
                    <Border
                        Padding="16"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{AppThemeBinding Light=#EEF6FF, Dark=#1E293B}"
                        Stroke="{AppThemeBinding Light=#D6E8FF, Dark=#334155}"
                        StrokeThickness="1">
                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Yaklaşan"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}"/>
                            <Label
                                Text="{Binding UpcomingExamCount}"
                                FontSize="28"
                                FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="16"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{AppThemeBinding Light=#F2FFF5, Dark=#1B2E22}"
                        Stroke="{AppThemeBinding Light=#D8F5E1, Dark=#355844}"
                        StrokeThickness="1">
                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Tamamlanan"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}"/>
                            <Label
                                Text="{Binding CompletedExamCount}"
                                FontSize="28"
                                FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Exam Card Section -->
                <Label
                    Text="Sıradaki Sınav"
                    FontSize="22"
                    FontAttributes="Bold"
                    Margin="0,24,0,8"/>

                <Border
                    IsVisible="{Binding HasExamToday}"
                    Padding="16"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                    StrokeThickness="1"
                    Margin="0,0,0,8">
                    <VerticalStackLayout Spacing="12">
                        <Label
                            Text="{Binding NextExam.CourseName}"
                            FontSize="20"
                            FontAttributes="Bold"/>
                        <Grid
                            ColumnDefinitions="Auto,*"
                            RowDefinitions="Auto,Auto,Auto"
                            ColumnSpacing="8"
                            RowSpacing="8">
                            <Label
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="🕘"/>
                            <Label
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding NextExam.FormattedTime}"/>
                            <Label
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="🏫"/>
                            <Label
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="{Binding NextExam.Building}"/>
                            <Label
                                Grid.Row="2"
                                Grid.Column="0"
                                Text="🚪"/>
                            <Label
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="{Binding NextExam.Classroom}"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                            <Button
                                Grid.Column="0"
                                Text="Detayları Gör"
                                Command="{Binding OpenExamDetailCommand}"
                                CornerRadius="12" />
                            <Button
                                Grid.Column="1"
                                Text="QR Kodunu Göster"
                                Command="{Binding ShowQrCommand}"
                                CornerRadius="12" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border
                    IsVisible="{Binding HasNoExamToday}"
                    Padding="16"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                    StrokeThickness="1"
                    Margin="0,0,0,8">
                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="🎉 Bugün sınavınız bulunmuyor"
                            FontSize="20"
                            FontAttributes="Bold"
                            HorizontalOptions="Center" />
                        <Label
                            Text="Bugün için planlanmış bir sınavınız bulunmamaktadır."
                            FontSize="14"
                            TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>