<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Exam_Organisation_System.Views.HomePage">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout
                Padding="24,12,24,24"
                Spacing="12">
                <Label
                    Text="Merhaba,"
                    FontSize="18"
                    />
                <Label
                    x:Name="StudentNameLabel"
                    Text="Mehmet Dilşad Butekin"
                    FontSize="28"
                />
                <Label
                    Text="9 Temmuz 2026"
                    FontSize="14"
                    TextColor="Gray"
                    Margin="0,0,0,8" />

                <!-- Exam Card Section -->
                <Label
                    Text="Sıradaki Sınav"
                    FontSize="22"
                    FontAttributes="Bold"
                    Margin="0,24,0,8"/>

                <Border
                    Padding="16"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    Margin="0,0,0,8">
                    <VerticalStackLayout Spacing="12">
                        <Label
                            Text="Database Management Systems"
                            FontSize="20"
                            FontAttributes="Bold"/>
                        <Grid
                            ColumnDefinitions="Auto,*"
                            RowDefinitions="Auto,Auto,Auto"
                            ColumnSpacing="8"
                            RowSpacing="8">
                            <Label
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="🕘"/>
                            <Label
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="09:30"/>
                            <Label
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="🏫"/>
                            <Label
                                x:Name="NameOfBuilding"
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="Bilgisayar Mühendisliği Binası"/>
                            <Label
                                Grid.Row="2"
                                Grid.Column="0"
                                Text="🚪"/>
                            <Label
                                x:Name="NameOfClass"
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="Yazılım 1"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                            <Button
                                Grid.Column="0"
                                Text="Detayları Gör"
                                Clicked="OnExamDetailClicked"
                                CornerRadius="12" />
                            <Button
                                Grid.Column="1"
                                Text="QR Kodunu Göster"
                                Clicked="OnShowQrClicked"
                                CornerRadius="12" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>