<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Exam_Organisation_System.Views.ExamDetailPage">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="20">

                <Label
                    Text="Sınav Detayı"
                    FontSize="28"
                    FontAttributes="Bold" />

                <Border Padding="20"
                        Stroke="#E5E7EB"
                        StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="10">
                        <Label
                               Text="{Binding SelectedExam.CourseName}"
                               FontSize="24"
                               FontAttributes="Bold" />
                        <Label Text="{Binding SelectedExam.ExamDate}" />
                        <Label Text="{Binding SelectedExam.ExamTime}" />
                        <Label Text="{Binding SelectedExam.Building}" />
                        <Label Text="{Binding SelectedExam.Classroom}" />
                        <Label Text="{Binding SelectedExam.Supervisor}" />
                    </VerticalStackLayout>
                </Border>

                <Border Padding="16"
                        Stroke="#E5E7EB"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Sınav Bilgilendirmesi"
                               FontAttributes="Bold"
                               FontSize="18" />
                        <Label Text="{Binding SelectedExam.Description}" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="QR Kodunu Göster"
                        Command="{Binding ShowQrCommand}"
                        CornerRadius="12"
                        HeightRequest="52" />

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>