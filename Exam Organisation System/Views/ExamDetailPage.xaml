<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Exam_Organisation_System.Views.ExamDetailPage">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="20">

                <Label
                    Text="Sınav Detayı"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />

                <Border Padding="20"
                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                        StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="10">
                        <Label
                               Text="{Binding SelectedExam.CourseName}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />
                        <Label Text="{Binding SelectedExam.ExamDate}" />
                        <Label Text="{Binding SelectedExam.ExamTime}" />
                        <Label Text="{Binding SelectedExam.Building}" />
                        <Label Text="{Binding SelectedExam.Classroom}" />
                        <Label Text="{Binding SelectedExam.Supervisor}" />
                    </VerticalStackLayout>
                </Border>

                <Border Padding="16"
                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Sınav Bilgilendirmesi"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />
                        <Label Text="{Binding SelectedExam.Description}" LineBreakMode="WordWrap" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="QR Kodunu Göster"
                        Command="{Binding ShowQrCommand}"
                        IsVisible="{Binding ShowQrButton}"
                        CornerRadius="12"
                        HeightRequest="52" />

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>