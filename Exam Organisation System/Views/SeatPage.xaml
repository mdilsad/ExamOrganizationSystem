<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Exam_Organisation_System.Views.SeatPage">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout
                Padding="24"
                Spacing="20">

                <Label
                    Text="Sınav Bilgileri"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />

                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3A}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20">

                    <VerticalStackLayout Spacing="12">

                        <Label
                            Text="{Binding SelectedExam.CourseName}"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light=#1F2937, Dark=White}" />

                        <Label Text="{Binding SelectedExam.FormattedDate}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <Label Text="{Binding SelectedExam.FormattedTime}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <Label Text="{Binding SelectedExam.Building}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <Label Text="{Binding SelectedExam.Classroom}" TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    </VerticalStackLayout>
                </Border>

                <Border
                    Padding="30"
                    BackgroundColor="{AppThemeBinding Light=#006633, Dark=#0A8A46}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="12">

                        <Label
                            Text="Sıra Numaranız"
                            TextColor="White"
                            FontSize="20" />

                        <Label
                            Text="{Binding Seat.SeatNumber}"
                            FontSize="64"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="{Binding Seat.Row, StringFormat='Satır: {0}'}"
                            TextColor="White"
                            FontSize="18"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="{Binding Seat.Column, StringFormat='Sütun: {0}'}"
                            TextColor="White"
                            FontSize="18"
                            HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>
                </Border>

                <Label
                    Text="{Binding StatusMessage}"
                    TextColor="Red"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding HasStatusMessage}" />

                <Button
                    Text="Ana Sayfaya Dön"
                    Command="{Binding BackToHomeCommand}"
                    CornerRadius="14" />

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>