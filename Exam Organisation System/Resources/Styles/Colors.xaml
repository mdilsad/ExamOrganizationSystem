<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Çukurova University Theme -->

    <!-- Base colors required by the default MAUI Styles.xaml -->
    <Color x:Key="Primary">#006B2D</Color>
    <Color x:Key="PrimaryDark">#005624</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#0A8F45</Color>
    <Color x:Key="SecondaryDarkText">#FFFFFF</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#111111</Color>

    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray900">#1F2937</Color>
    <Color x:Key="Gray950">#111827</Color>

    <Color x:Key="MidnightBlue">#1F2937</Color>
    <Color x:Key="Magenta">#006B2D</Color>

    <!-- Project semantic colors -->
    <Color x:Key="PrimaryColor">#006B2D</Color>
    <Color x:Key="SecondaryColor">#0A8F45</Color>
    <Color x:Key="AccentColor">#4CAF50</Color>

    <Color x:Key="BackgroundColor">#F7F8F7</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>

    <Color x:Key="PrimaryTextColor">#1F2937</Color>
    <Color x:Key="SecondaryTextColor">#6B7280</Color>

    <Color x:Key="BorderColor">#D1D5DB</Color>

    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="ErrorColor">#DC2626</Color>

</ResourceDictionary>